<mvc:View
  controllerName="BridgeManagement.bmsadmin.controller.AttributeConfig"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:grid="sap.ui.layout.cssgrid"
  xmlns:layout="sap.ui.layout"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
  displayBlock="true">

  <f:DynamicPage id="mainPage" headerExpanded="true" toggleHeaderOnTitleClick="false" showFooter="false">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading><Title text="Attribute Configuration" level="H2"/></f:heading>
        <f:snappedHeading><Title text="Attribute Configuration" level="H2"/></f:snappedHeading>
        <f:actions>
          <SegmentedButton id="objectTypeSelector" selectionChange=".onObjectTypeChange"/>
          <Button text="Template" icon="sap-icon://download" press=".onExportTemplate" type="Transparent" tooltip="Download an Excel template for bulk value entry"/>
          <Button text="Import" icon="sap-icon://upload" press=".onImportValues" type="Transparent" tooltip="Bulk create/update attribute values from a filled template"/>
          <Button icon="sap-icon://sys-help" tooltip="How to use Attribute Configuration" press=".onShowHelp" type="Transparent"/>
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <!-- Responsive 3-column layout: 3 columns on L/XL, stacked on M/S -->
      <layout:Grid defaultSpan="XL4 L4 M12 S12" hSpacing="1" vSpacing="1" width="100%">

        <!-- ════ Column 1: Attribute Groups (the "class") ════ -->
        <Panel headerText="Attribute Groups" class="sapUiResponsiveMargin" width="auto">
          <headerToolbar>
            <OverflowToolbar>
              <Title text="Attribute Groups"/>
              <ToolbarSpacer/>
              <Button icon="sap-icon://add" text="New" type="Emphasized" press=".onAddGroup" tooltip="Add a new attribute group"/>
            </OverflowToolbar>
          </headerToolbar>
          <VBox>
            <SearchField id="groupSearch" placeholder="Search groups…" liveChange=".onGroupSearch" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"/>
            <List id="groupList" items="{/}" mode="SingleSelectMaster" selectionChange=".onGroupSelect"
                  growing="true" growingThreshold="50">
              <StandardListItem
                icon="sap-icon://folder-full"
                title="{name}"
                description="{internalKey}"
                info="{status}"
                infoState="{path:'status', formatter:'.fmt.statusState'}"
                type="Active"/>
            </List>
            <VBox id="groupEmpty" alignItems="Center" justifyContent="Center" class="sapUiMediumMargin" visible="false">
              <core:Icon src="sap-icon://customize" size="2.5rem" color="#9ba4ab"/>
              <Text text="No groups for this object type yet." textAlign="Center" class="sapUiSmallMarginTop"/>
              <Button text="Create your first group" type="Emphasized" icon="sap-icon://add" press=".onAddGroup" class="sapUiSmallMarginTop"/>
            </VBox>
          </VBox>
        </Panel>

        <!-- ════ Column 2: Attribute Definitions (the "characteristics") ════ -->
        <Panel id="defsPanel" headerText="Attributes" class="sapUiResponsiveMargin" width="auto" visible="false">
          <headerToolbar>
            <OverflowToolbar>
              <Title id="defsTitle" text="Attributes"/>
              <ToolbarSpacer/>
              <Button icon="sap-icon://edit" tooltip="Edit group" press=".onEditGroup"/>
              <Button icon="sap-icon://delete" type="Transparent" tooltip="Delete group" press=".onDeleteGroup"/>
              <Button icon="sap-icon://add" text="New" type="Emphasized" tooltip="Add attribute" press=".onAddAttribute"/>
            </OverflowToolbar>
          </headerToolbar>
          <VBox>
            <SearchField id="attrSearch" placeholder="Search attributes…" liveChange=".onAttrSearch" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"/>
            <List id="attrList" items="{/}" mode="SingleSelectMaster" selectionChange=".onAttrSelect" noDataText="No attributes in this group yet">
              <StandardListItem
                icon="{path:'dataType', formatter:'.fmt.dataTypeIcon'}"
                title="{name}"
                description="{parts:['dataType','unit'], formatter:'.fmt.attrSubtitle'}"
                info="{status}"
                infoState="{path:'status', formatter:'.fmt.statusState'}"
                type="Active"/>
            </List>
          </VBox>
        </Panel>

        <!-- ════ Column 3: Attribute Detail ════ -->
        <Panel id="attrDetailPanel" headerText="Attribute Detail" class="sapUiResponsiveMargin" width="auto" visible="false">
          <headerToolbar>
            <OverflowToolbar>
              <Title id="detailHeading" text="Attribute Detail"/>
              <ToolbarSpacer/>
              <Button icon="sap-icon://edit" text="Edit" press=".onEditAttribute"/>
              <Button icon="sap-icon://delete" type="Transparent" tooltip="Delete attribute" press=".onDeleteAttribute"/>
            </OverflowToolbar>
          </headerToolbar>

          <VBox class="sapUiSmallMargin">
            <ObjectStatus id="detailStatus" class="sapUiTinyMarginBottom"/>
            <form:SimpleForm editable="false" layout="ResponsiveGridLayout" columnsL="1" columnsM="1" labelSpanL="5" labelSpanM="5">
              <form:content>
                <Label text="Name"/><Text id="detailName"/>
                <Label text="Internal Key"/><Text id="detailKey"/>
                <Label text="Data Type"/><Text id="detailType"/>
                <Label text="Unit"/><Text id="detailUnit"/>
                <Label text="Help Text"/><Text id="detailHelp"/>
                <Label text="Min / Max"/><Text id="detailRange"/>
              </form:content>
            </form:SimpleForm>

            <!-- Object-type assignment -->
            <Title text="Assigned Object Types" level="H5" class="sapUiTinyMarginTop"/>
            <Text text="Enable this attribute for an object type and choose whether it is mandatory." class="sapUiTinyMarginBottom"/>
            <Table id="configTable" items="{/}" noDataText="No object types">
              <columns>
                <Column><Text text="Object Type"/></Column>
                <Column hAlign="Center"><Text text="Enabled"/></Column>
                <Column hAlign="Center"><Text text="Required"/></Column>
                <Column hAlign="Center" width="6rem"><Text text="Order"/></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{path:'objectType', formatter:'.fmt.objectTypeLabel'}"/>
                    <Switch state="{enabled}" change=".onConfigRowChange"/>
                    <Switch state="{required}" change=".onConfigRowChange"/>
                    <Input value="{displayOrder}" type="Number" width="5rem" change=".onConfigRowChange"/>
                  </cells>
                </ColumnListItem>
              </items>
            </Table>

            <!-- Allowed values (select types only) -->
            <Title id="allowedValuesTitle" text="Allowed Values" level="H5" class="sapUiSmallMarginTop"/>
            <MessageStrip id="allowedValuesHint" type="Information" showIcon="true"
                          text="Allowed values apply only to Single-Select and Multi-Select attributes."
                          class="sapUiTinyMarginBottom" visible="false"/>
            <OverflowToolbar id="allowedValuesToolbar">
              <ToolbarSpacer/>
              <Button icon="sap-icon://add" text="Add Value" press=".onAddAllowedValue" type="Emphasized"/>
            </OverflowToolbar>
            <Table id="allowedValuesTable" items="{/}" noDataText="No values yet">
              <columns>
                <Column><Text text="Value"/></Column>
                <Column><Text text="Label"/></Column>
                <Column hAlign="Center" width="9rem"><Text text="Reorder"/></Column>
                <Column hAlign="End" width="6rem"><Text text="Actions"/></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{value}"/>
                    <Text text="{label}"/>
                    <HBox justifyContent="Center">
                      <Button icon="sap-icon://slim-arrow-up" type="Transparent" tooltip="Move up" press=".onMoveAllowedValueUp"/>
                      <Button icon="sap-icon://slim-arrow-down" type="Transparent" tooltip="Move down" press=".onMoveAllowedValueDown"/>
                    </HBox>
                    <HBox justifyContent="End">
                      <Button icon="sap-icon://edit" type="Transparent" tooltip="Edit value" press=".onEditAllowedValue"/>
                      <Button icon="sap-icon://delete" type="Transparent" tooltip="Delete value" press=".onDeleteAllowedValue"/>
                    </HBox>
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </VBox>
        </Panel>

      </layout:Grid>
    </f:content>
  </f:DynamicPage>
</mvc:View>
