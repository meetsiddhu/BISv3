<mvc:View
  controllerName="BridgeManagement.bmsadmin.controller.AssetStrategy"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  displayBlock="true">

  <Page id="assetStrategyPage" showHeader="true" title="{i18n>nav.assetStrategy}">
    <customHeader>
      <Bar>
        <contentLeft>
          <Title text="{i18n>assetStrategy.title}" level="H3" />
        </contentLeft>
        <contentRight>
          <Button icon="sap-icon://refresh" text="{i18n>btn.refresh}" press=".onRefresh" type="Transparent" />
          <Button icon="sap-icon://add" text="{i18n>btn.add}" press=".onAdd" type="Emphasized" class="sapUiSmallMarginBegin" />
          <Button icon="sap-icon://sys-help" tooltip="{i18n>btn.help}" press=".onShowHelp" type="Transparent" class="sapUiSmallMarginBegin" />
        </contentRight>
      </Bar>
    </customHeader>
    <content>
      <MessageStrip text="{i18n>assetStrategy.note}" type="Information" showIcon="true" class="sapUiSmallMargin" />
      <Table id="assetStrategyTable" items="{/rows}" growing="true" growingThreshold="50"
             noDataText="{i18n>assetStrategy.noData}" class="sapUiSmallMarginBegin sapUiSmallMarginEnd">
        <columns>
          <Column><Text text="{i18n>assetStrategy.col.name}" /></Column>
          <Column><Text text="{i18n>assetStrategy.col.assetClass}" /></Column>
          <Column><Text text="{i18n>assetStrategy.col.mode}" /></Column>
          <Column hAlign="End" width="9rem"><Text text="{i18n>assetStrategy.col.interval}" /></Column>
          <Column hAlign="End" width="9rem"><Text text="{i18n>assetStrategy.col.target}" /></Column>
          <Column hAlign="End" width="10rem"><Text text="{i18n>assetStrategy.col.intervention}" /></Column>
          <Column hAlign="Center" width="7rem"><Text text="{i18n>col.active}" /></Column>
          <Column hAlign="End" width="6rem"><Text text="{i18n>col.actions}" /></Column>
        </columns>
        <items>
          <ColumnListItem>
            <cells>
              <ObjectIdentifier title="{name}" />
              <Text text="{assetClass}" />
              <Text text="{transportMode}" />
              <ObjectNumber number="{inspectionIntervalMonths}" unit="mo" />
              <ObjectNumber number="{targetConditionRating}" />
              <ObjectNumber number="{interventionThreshold}" />
              <Switch state="{= ${active} !== false}" change=".onToggleActive" customTextOn=" " customTextOff=" " />
              <Button icon="sap-icon://edit" type="Transparent" press=".onEdit" tooltip="{i18n>btn.edit}" />
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </content>
  </Page>
</mvc:View>
