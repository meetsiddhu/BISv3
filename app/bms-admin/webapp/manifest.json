{
  "_version": "1.8.0",
  "sap.app": {
    "id": "BridgeManagement.bmsadmin",
    "type": "application",
    "title": "BMS Administration",
    "description": "Bridge Management System Administration",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": { "version": "1.1.0" },
    "dataSources": {
      "AdminService":      { "uri": "/odata/v4/admin/",    "type": "OData", "settings": { "odataVersion": "4.0" } },
      "AuditService":      { "uri": "/audit/api/",         "type": "HTTP" },
      "SystemService":     { "uri": "/system/api/",        "type": "HTTP" },
      "BnacService":       { "uri": "/bnac/api/",          "type": "HTTP" },
      "AttributesService": { "uri": "/attributes/api/",   "type": "HTTP" }
    },
    "crossNavigation": {
      "inbounds": {
        "BmsAdmin-manage": {
          "signature": { "parameters": {}, "additionalParameters": "allowed" },
          "semanticObject": "BmsAdmin",
          "action": "manage",
          "title": "BMS Administration",
          "info": "Manage reference data, audit logs, data quality, user access, system config and integrations",
          "icon": "sap-icon://action-settings"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "fullWidth": true,
    "deviceTypes": { "desktop": true, "phone": false, "tablet": true }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.m": {},
        "sap.tnt": {},
        "sap.f": {},
        "sap.ui.layout": {},
        "sap.ui.table": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties",
        "settings": { "supportedLocales": [""], "fallbackLocale": "" }
      },
      "appConfig": {
        "type": "sap.ui.model.json.JSONModel",
        "settings": {
          "data": {
            "layerCategories": ["Weather","Flood","Traffic","Geology","Infrastructure","Environment","Emergency","Administrative","Custom"],
            "layerTypes": ["WMS","XYZ","ArcGISRest","GeoJSON"],
            "attributeDataTypes": ["Text","Integer","Decimal","Date","Boolean","SingleSelect","MultiSelect"],
            "attributeObjectTypes": ["bridge","restriction"],
            "attributeStatuses": ["Active","Inactive"]
          }
        }
      }
    },
    "rootView": {
      "viewName": "BridgeManagement.bmsadmin.view.Shell",
      "type": "XML",
      "id": "bmsAdminShell"
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "BridgeManagement.bmsadmin.view",
        "controlId": "adminNavContainer",
        "controlAggregation": "pages",
        "bypassed": { "target": "changeDocuments" }
      },
      "routes": [
        { "pattern": "", "name": "home", "target": "changeDocuments" },
        { "pattern": "change-documents", "name": "changeDocuments", "target": "changeDocuments" },
        { "pattern": "system-config", "name": "systemConfig", "target": "systemConfig" },
        { "pattern": "bnac-config", "name": "bnacConfig", "target": "bnacConfig" },
        { "pattern": "attribute-config", "name": "attributeConfig", "target": "attributeConfig" },
        { "pattern": "gis-config",       "name": "gisConfig",       "target": "gisConfig" },
        { "pattern": "risk-bands",       "name": "riskBands",       "target": "riskBands" },
        { "pattern": "risk-factors",     "name": "riskFactors",     "target": "riskFactors" },
        { "pattern": "asset-strategy",   "name": "assetStrategy",   "target": "assetStrategy" },
        { "pattern": "demo-mode",        "name": "demoMode",        "target": "demoMode" }
      ],
      "targets": {
        "changeDocuments": { "viewName": "ChangeDocuments",  "viewLevel": 1 },
        "systemConfig":    { "viewName": "SystemConfig",     "viewLevel": 1 },
        "bnacConfig":      { "viewName": "BnacConfig",       "viewLevel": 1 },
        "attributeConfig": { "viewName": "AttributeConfig",  "viewLevel": 1 },
        "gisConfig":       { "viewName": "GisConfig",        "viewLevel": 1 },
        "riskBands":       { "viewName": "RiskBands",        "viewLevel": 1 },
        "riskFactors":     { "viewName": "RiskFactors",      "viewLevel": 1 },
        "assetStrategy":   { "viewName": "AssetStrategy",    "viewLevel": 1 },
        "demoMode":        { "viewName": "DemoMode",         "viewLevel": 1 }
      }
    },
    "contentDensities": { "compact": true, "cozy": true }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "analytical"
  }
}
