          "supportedLocales": [
            ""
          ],
          "fallbackLocale": ""
        }
      },
      "appConfig": {
        "type": "sap.ui.model.json.JSONModel",
        "settings": {
          "data": {
            "layerCategories": [
              "Weather",
              "Flood",
              "Traffic",
              "Geology",
              "Infrastructure",
              "Environment",
              "Emergency",
              "Administrative",
              "Custom"
            ],
            "layerTypes": [
              "WMS",
              "XYZ",
              "ArcGISRest",
              "GeoJSON"
            ]
          }
        }
      },
      "": {
        "dataSource": "AdminService",
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "routes": [
        {
          "pattern": ":?query:",
          "name": "BridgesList",
          "target": "BridgesList"
        },
        {
          "pattern": "Bridges({key}):?query:",
          "name": "BridgesDetails",
          "target": "BridgesDetails"
        },
        {
          "pattern": "GISConfig:?query:",
          "name": "GISConfig",
          "target": "GISConfig"
        },
        {
          "pattern": "BridgeCapacities:?query:",
          "name": "BridgeCapacitiesList",
          "target": "BridgeCapacitiesList"
        },
        {
          "pattern": "BridgeCapacities({key}):?query:",
          "name": "BridgeCapacitiesPage",
          "target": "BridgeCapacitiesPage"
        },
        {
          "pattern": "BridgeRestrictions:?query:",
          "name": "BridgeRestrictionsList",
          "target": "BridgeRestrictionsList"
        },
        {
          "pattern": "BridgeRestrictions({key}):?query:",
          "name": "BridgeRestrictionsPage",
          "target": "BridgeRestrictionsPage"
        },
        {
          "pattern": "BridgeInspections:?query:",
          "name": "BridgeInspectionsList",
          "target": "BridgeInspectionsList"
        },
        {
          "pattern": "BridgeInspections({key}):?query:",
          "name": "BridgeInspectionsPage",
          "target": "BridgeInspectionsPage"
        },
        {
          "pattern": "BridgeDefects:?query:",
          "name": "BridgeDefectsList",
          "target": "BridgeDefectsList"
        },
        {
          "pattern": "BridgeDefects({key}):?query:",
          "name": "BridgeDefectsPage",
          "target": "BridgeDefectsPage"
        },
        {
          "name": "ChangeDocumentReportList",
          "pattern": "ChangeDocumentReport:?query:",
          "target": "ChangeDocumentReportList"
        },
        {
          "name": "EAMCodeMappingList",
          "pattern": "EAMCodeMapping:?query:",
          "target": "EAMCodeMappingList"
        },
        {
          "name": "EAMCodeMappingPage",
          "pattern": "EAMCodeMapping({key}):?query:",
          "target": "EAMCodeMappingPage"
        },
        {
          "name": "AttributeGroupsList",
          "pattern": "AttributeGroups:?query:",
          "target": "AttributeGroupsList"
        },
        {
          "name": "AttributeGroupsPage",
          "pattern": "AttributeGroups({key}):?query:",
          "target": "AttributeGroupsPage"
        },
        {
          "name": "AttributeDefinitionsPage",
          "pattern": "AttributeGroups({key})/definitions({key2}):?query:",
