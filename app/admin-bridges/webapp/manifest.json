{
  "_version": "1.8.0",
  "sap.app": {
    "id": "BridgeManagement.adminbridges",
    "type": "application",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "i18n": { "bundleUrl": "i18n/i18n.properties", "supportedLocales": [""], "fallbackLocale": "" },
    "applicationVersion": {
      "version": "1.0.0"
    },
    "dataSources": {
      "AdminService": {
        "uri": "/odata/v4/admin/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      },
      "AdminBridgesService": { "uri": "/admin-bridges/api/", "type": "HTTP" }
    },
    "crossNavigation": {
      "inbounds": {
        "Bridges-manage": {
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          },
          "semanticObject": "Bridges",
          "action": "manage",
          "title": "{{appTitle}}",
          "info": "{{appDescription}}",
          "subTitle": "{{appSubTitle}}",
          "icon": "sap-icon://course-book"
        },
        "BridgeInspections-manage": {
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          },
          "semanticObject": "BridgeInspections",
          "action": "manage",
          "title": "Inspections",
          "subTitle": "All Bridge Inspections",
          "icon": "sap-icon://inspection"
        },
        "BridgeDefects-manage": {
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          },
          "semanticObject": "BridgeDefects",
          "action": "manage",
          "title": "Defects",
          "subTitle": "Create & Manage Defects",
          "icon": "sap-icon://quality-issue"
        },
        "BridgeCapacities-manage": {
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          },
          "semanticObject": "BridgeCapacities",
          "action": "manage",
          "title": "Bridge Capacity",
          "subTitle": "Load & Geometric Capacities",
          "icon": "sap-icon://simulate"
        }
      }
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.136.0",
      "libs": {
        "sap.fe.templates": {},
        "sap.ui.layout": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties",
        "settings": { "supportedLocales": [""], "fallbackLocale": "" }
      },
      "appConfig": {
        "type": "sap.ui.model.json.JSONModel",
        "settings": {
          "data": {
            "layerCategories": ["Weather","Flood","Traffic","Geology","Infrastructure","Environment","Emergency","Administrative","Custom"],
            "layerTypes": ["WMS","XYZ","ArcGISRest","GeoJSON"]
          }
        }
      },
      "": {
        "dataSource": "AdminService",
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "routing": {
      "routes": [
        {
          "pattern": ":?query:",
          "name": "BridgesList",
          "target": "BridgesList"
        },
        {
          "pattern": "Bridges({key}):?query:",
          "name": "BridgesDetails",
          "target": "BridgesDetails"
        },
        {
          "pattern": "GISConfig:?query:",
          "name": "GISConfig",
          "target": "GISConfig"
        },
        {
          "pattern": "BridgeCapacities:?query:",
          "name": "BridgeCapacitiesList",
          "target": "BridgeCapacitiesList"
        },
        {
          "pattern": "BridgeCapacities({key}):?query:",
          "name": "BridgeCapacitiesPage",
          "target": "BridgeCapacitiesPage"
        },
        {
          "pattern": "BridgeRestrictions:?query:",
          "name": "BridgeRestrictionsList",
          "target": "BridgeRestrictionsList"
        },
        {
          "pattern": "BridgeRestrictions({key}):?query:",
          "name": "BridgeRestrictionsPage",
          "target": "BridgeRestrictionsPage"
        },
        {
          "pattern": "BridgeInspections:?query:",
          "name": "BridgeInspectionsList",
          "target": "BridgeInspectionsList"
        },
        {
          "pattern": "BridgeInspections({key}):?query:",
          "name": "BridgeInspectionsPage",
          "target": "BridgeInspectionsPage"
        },
        {
          "pattern": "BridgeDefects:?query:",
          "name": "BridgeDefectsList",
          "target": "BridgeDefectsList"
        },
        {
          "pattern": "BridgeDefects({key}):?query:",
          "name": "BridgeDefectsPage",
          "target": "BridgeDefectsPage"
        }
      ],
      "targets": {
        "GISConfig": {
          "type": "XMLView",
          "id": "GISConfig",
          "viewName": "BridgeManagement.adminbridges.ext.view.GISConfig",
          "viewLevel": 1,
          "controlAggregation": "midColumnPages",
          "controlId": "fcl"
        },
        "BridgesList": {
          "type": "Component",
          "id": "BridgesList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "Bridges",
              "liveMode": false,
              "initialLoad": "Enabled",
              "filterDefaultValues": {
                "status": "Active"
              },
              "navigation": {
                "Bridges": {
                  "detail": {
                    "route": "BridgesDetails"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "actions": {
                    "exportCsv": {
                      "press": "BridgeManagement.adminbridges.ext.controller.ListReportExt.onExportCsv",
                      "text": "Export CSV",
                      "enabled": true,
                      "requiresSelection": false
                    }
                  }
                }
              }
            }
          }
        },
        "BridgesDetails": {
          "type": "Component",
          "id": "BridgesDetailsList",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "Bridges",
              "editableHeaderContent": false,
              "sharingEnabled": false,
              "controlConfiguration": {
                "documents/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": { "enablePaste": false }
                }
              },
              "content": {
                "body": {
                  "sections": {
                    "attachmentsSection": {
                      "template": "BridgeManagement.adminbridges.ext.fragment.Attachments",
                      "title": "Attachments",
                      "position": {
                        "placement": "Before",
                        "anchor": "DataProvenance"
                      }
                    },
                    "mapSection": {
                      "template": "BridgeManagement.adminbridges.ext.fragment.GisMapTab",
                      "title": "Map",
                      "position": {
                        "placement": "After",
                        "anchor": "GeneralInformation"
                      }
                    },
                    "customAttributesSection": {
                      "template": "BridgeManagement.adminbridges.ext.fragment.CustomAttributes",
                      "title": "Custom Attributes",
                      "position": {
                        "placement": "After",
                        "anchor": "mapSection"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "BridgeCapacitiesList": {
          "type": "Component",
          "id": "BridgeCapacitiesList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "BridgeCapacities",
              "liveMode": false,
              "initialLoad": "Enabled",
              "filterDefaultValues": {
                "IsActiveEntity": true
              },
              "navigation": {
                "BridgeCapacities": { "detail": { "route": "BridgeCapacitiesPage" } }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "enablePaste": false,
                    "creationMode": {
                      "name": "NewPage"
                    }
                  }
                }
              }
            }
          }
        },
        "BridgeCapacitiesPage": {
          "type": "Component",
          "id": "BridgeCapacitiesPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "BridgeCapacities",
              "editableHeaderContent": false,
              "sharingEnabled": false
            }
          }
        },
        "BridgeRestrictionsList": {
          "type": "Component",
          "id": "BridgeRestrictionsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "BridgeRestrictions",
              "navigation": {
                "BridgeRestrictions": { "detail": { "route": "BridgeRestrictionsPage" } }
              }
            }
          }
        },
        "BridgeRestrictionsPage": {
          "type": "Component",
          "id": "BridgeRestrictionsPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "BridgeRestrictions",
              "editableHeaderContent": false,
              "sharingEnabled": false
            }
          }
        },
        "BridgeInspectionsList": {
          "type": "Component",
          "id": "BridgeInspectionsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "BridgeInspections",
              "liveMode": false,
              "initialLoad": "Enabled",
              "filterDefaultValues": {
                "IsActiveEntity": true
              },
              "navigation": {
                "BridgeInspections": { "detail": { "route": "BridgeInspectionsPage" } }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "enablePaste": false,
                    "creationMode": {
                      "name": "NewPage"
                    }
                  }
                }
              }
            }
          }
        },
        "BridgeInspectionsPage": {
          "type": "Component",
          "id": "BridgeInspectionsPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "BridgeInspections",
              "editableHeaderContent": false,
              "sharingEnabled": false
            }
          }
        },
        "BridgeDefectsList": {
          "type": "Component",
          "id": "BridgeDefectsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "BridgeDefects",
              "liveMode": false,
              "initialLoad": "Enabled",
              "filterDefaultValues": {
                "IsActiveEntity": true
              },
              "navigation": {
                "BridgeDefects": { "detail": { "route": "BridgeDefectsPage" } }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "enablePaste": false,
                    "creationMode": {
                      "name": "NewPage"
                    }
                  }
                }
              }
            }
          }
        },
        "BridgeDefectsPage": {
          "type": "Component",
          "id": "BridgeDefectsPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "BridgeDefects",
              "editableHeaderContent": false,
              "sharingEnabled": false
            }
          }
        }
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "phone": true,
      "tablet": true
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
